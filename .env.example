# Movie Magic Environment Variables
# Copy this file to .env and fill in your values

# Flask Configuration
SECRET_KEY=your-secret-key-here
FLASK_DEBUG=True
DATABASE_URL=sqlite:///moviemagic.db

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# DynamoDB Tables
DYNAMODB_TABLE_USERS=MovieMagicUsers
DYNAMODB_TABLE_MOVIES=MovieMagicMovies
DYNAMODB_TABLE_BOOKINGS=MovieMagicBookings

# SNS Configuration
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:MovieMagicNotifications

